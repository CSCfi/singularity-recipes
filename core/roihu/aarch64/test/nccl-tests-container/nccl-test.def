Bootstrap: localimage
From: {{BASE_IMAGE}}

%arguments
    BASE_IMAGE=
    NPROCS=10

%post
    # Install tools
    dnf install -y wget file which

    git clone https://github.com/NVIDIA/nccl-tests.git nccl-tests
    cd nccl-tests
    export CUDA_HOME=/appl/soft/spack/core/v2026_03/g14cu129_eg/install_dir/linux-neoverse_v2/cuda-12.9.1-qxhpyt7nrfse2gtolnvv5u22kenlmg72
    export NCCL_INSTROOT=/appl/soft/spack/core/v2026_03/g14cu129_eg/install_dir/linux-neoverse_v2/nccl-2.28.7-1-jrqsrsz3cwy3vehhyqhnye6ofsoh77xz
    export OPENMPI_INSTROOT=/appl/soft/spack/core/v2026_03/g14cu129_eg/install_dir/linux-neoverse_v2/openmpi-5.0.8-5wh42xtnbe5ebjwre6q367d26ge2rktx
    make -j{{NPROCS}} CUDA_HOME=$CUDA_HOME NCCL_HOME=$NCCL_INSTROOT
    #make -j{{NPROCS}} CUDA_HOME=$CUDA_HOME NCCL_HOME=$NCCL_INSTROOT MPI=1 MPI_HOME=$OPENMPI_INSTROOT NAME_SUFFIX=_mpi

%environment
    export CUDA_HOME=/appl/soft/spack/core/v2026_03/g14cu129_eg/install_dir/linux-neoverse_v2/cuda-12.9.1-qxhpyt7nrfse2gtolnvv5u22kenlmg72
    export NCCL_INSTROOT=/appl/soft/spack/core/v2026_03/g14cu129_eg/install_dir/linux-neoverse_v2/nccl-2.28.7-1-jrqsrsz3cwy3vehhyqhnye6ofsoh77xz
    export OPENMPI_INSTROOT=/appl/soft/spack/core/v2026_03/g14cu129_eg/install_dir/linux-neoverse_v2/openmpi-5.0.8-5wh42xtnbe5ebjwre6q367d26ge2rktx
    export LD_LIBRARY_PATH=$CUDA_HOME/lib64:$NCCL_INSTROOT/lib:$OPENMPI_INSTROOT/lib:$LD_LIBRARY_PATH
