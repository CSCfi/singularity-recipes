Bootstrap: localimage
From: {{BASE_IMAGE}}

%arguments
    BASE_IMAGE=

%setup
    # Preserve symbolic links. Do NOT dereference.
    mkdir -p "$APPTAINER_ROOTFS/appl/modulefiles/spack"
    cp -r -d /appl/modulefiles/spack/aarch64 "$APPTAINER_ROOTFS/appl/modulefiles/spack/aarch64"
    mkdir -p "$APPTAINER_ROOTFS/appl/soft/spack/core/v2026_03"
    cp -r -d /appl/soft/spack/core/v2026_03/compilers_eg "$APPTAINER_ROOTFS/appl/soft/spack/core/v2026_03"
    cp -r -d /appl/soft/spack/core/v2026_03/g14cu129_eg "$APPTAINER_ROOTFS/appl/soft/spack/core/v2026_03"

%post
    cat > /opt/activate.sh << 'EOF'
export PATH=/appl/soft/spack/core/v2026_03/compilers_eg/install_dir/linux-neoverse_v2/binutils-2.45-iovy4emqxvyusjxcmgq6fendyvwibfxz/bin:$PATH
. /usr/share/lmod/9.1.2/init/bash
module use /appl/modulefiles/spack/aarch64/Core
module load gcc/14.3.0
module load openblas
module load openmpi
module load cuda
EOF
